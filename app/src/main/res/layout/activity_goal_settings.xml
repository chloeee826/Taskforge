<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/taskforge_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Goals"
            android:textColor="@color/taskforge_text"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Choose what a successful day looks like for each habit."
            android:textColor="@color/taskforge_muted"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="Drink Water (ml)"
            android:textColor="@color/taskforge_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/waterGoalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_goal_input"
            android:inputType="number"
            android:minHeight="52dp"
            android:textColor="@color/taskforge_text"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Exercise (min)"
            android:textColor="@color/taskforge_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/exerciseGoalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_goal_input"
            android:inputType="number"
            android:minHeight="52dp"
            android:textColor="@color/taskforge_text"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Sleep (hr)"
            android:textColor="@color/taskforge_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/sleepGoalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_goal_input"
            android:inputType="number"
            android:minHeight="52dp"
            android:textColor="@color/taskforge_text"
            android:textSize="18sp" />

        <Button
            android:id="@+id/saveGoalsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_primary_button"
            android:text="Save Goals"
            android:textAllCaps="false"
            android:textColor="@color/taskforge_text"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
